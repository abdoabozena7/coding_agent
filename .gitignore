# Secrets — never commit your real key
.env

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
venv/

# React/Vite development outputs (the production web/dist bundle is shipped)
web/node_modules/
web/*.tsbuildinfo
web/coverage/

# Workspace-local persistent harness state
.coding-agent/
**/run-artifacts/.ultra-staging/
run-artifacts/*.log

# Local browser automation state and disposable captures
.playwright-cli/
output/playwright/
output/verification/

# Per-run diagnostics (published evidence already tracked stays tracked)
projects/*/run-artifacts/
run-artifacts/*.err
run-artifacts/*.out

# One-off local state inspection helpers
projects/*/check_state.py
