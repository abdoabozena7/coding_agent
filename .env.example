# Copy this file to .env and fill in the key(s) for the provider you use:
#   cp .env.example .env
# The .env file is git-ignored, so your keys stay out of version control.

# Which LLM backend to use: openai (default), gemini, or ollama
LLM_PROVIDER=ollama

# Interactive policy: plan waits for an explicit /run after approval; goal
# continues automatically after the user explicitly approves the plan.
AGENT_MODE=plan

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini - https://aistudio.google.com/apikey  (only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Ollama - no API key needed.
# To change models, edit MODEL_NAME in agent/providers/ollama_provider.py.
# Optional temporary override:
# OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_HOST=http://localhost:11434

# Per-slice reliability limits (the durable goal itself has no time limit).
# AGENT_PLANNING_STEPS=16
# AGENT_WORK_QUANTUM=24
# AGENT_REVIEW_STEPS=12
# AGENT_SUBAGENT_STEPS=16
# AGENT_MAX_DELEGATION_DEPTH=4
# AGENT_MAX_DELEGATIONS_PER_SLICE=12
# AGENT_PROVIDER_RETRIES=3
# AGENT_REPEAT_LIMIT=2
# AGENT_NO_ACTION_LIMIT=3
# AGENT_STALLED_SLICE_LIMIT=3
# AGENT_CONTEXT_CHARS=120000
# AGENT_GOAL_RETRY_BASE_MS=1000
# AGENT_GOAL_RETRY_MAX_MS=30000
