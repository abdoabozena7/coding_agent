# Copy this file to .env and fill in the key(s) for the provider you use:
#   cp .env.example .env
# The .env file is git-ignored, so your keys stay out of version control.

# Which LLM backend to use: openai (default), gemini, or ollama
LLM_PROVIDER=ollama

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini - https://aistudio.google.com/apikey  (only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Ollama - no API key needed.
# To change models, edit MODEL_NAME in agent/providers/ollama_provider.py.
# Optional temporary override:
# OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_HOST=http://localhost:11434
