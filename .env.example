# Copy this file to .env and fill in the key(s) for the provider you use:
#   cp .env.example .env
# The .env file is git-ignored, so your keys stay out of version control.

# Which LLM backend to use: openai (default), gemini, or ollama
LLM_PROVIDER=ollama

# Public execution policy: Normal is always goal/plan/review/memory based;
# Ultra adds recursive specialists, architecture debate, and component consensus.
# Legacy chat/plan/goal values are accepted as aliases for Normal.
AGENT_MODE=normal

# Optional location for the local web application's project/thread registry.
# Workspace journals continue to live in each project's .coding-agent/state.db.
# GA3BAD_WEB_STATE_DIR=D:\path\to\private\app-data

# Development-only browser origin allowed by the FastAPI host/origin checks.
# Production is served from the same loopback origin as the API.
# GA3BAD_WEB_DEV_ORIGIN=http://127.0.0.1:5173

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini - https://aistudio.google.com/apikey  (only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Ollama - no API key needed.
# To change models, edit MODEL_NAME in agent/providers/ollama_provider.py.
# Optional temporary override:
# OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_HOST=http://localhost:11434
# Bound local KV-cache memory; override for larger-memory machines.
OLLAMA_CONTEXT_SIZE=16384
# Optional real semantic repository embeddings. If unset, the index uses a
# deterministic offline hashing fallback. Recommended when the model is installed:
# AGENT_EMBEDDING_MODEL=nomic-embed-text:latest
# Optional: set 0 when automatic GPU offload fails or repeatedly runs out of VRAM.
# OLLAMA_NUM_GPU=0
# Optional: require a detected local GPU before local/Ollama ULTRA runs start.
# This prevents misleading CPU fallback benchmarks for weak local models.
# AGENT_REQUIRE_LOCAL_GPU=1

# Per-slice reliability limits (the durable goal itself has no time limit).
# AGENT_PLANNING_STEPS=16
# AGENT_WORK_QUANTUM=24
# AGENT_REVIEW_STEPS=12
# AGENT_SUBAGENT_STEPS=16
# AGENT_MAX_DELEGATION_DEPTH=4
# AGENT_MAX_DELEGATIONS_PER_SLICE=12
# AGENT_PROVIDER_RETRIES=3
# Consecutive provider-failure cycles before pausing for model/network repair.
# AGENT_PROVIDER_FAILURE_LIMIT=3
# AGENT_REPEAT_LIMIT=2
# AGENT_NO_ACTION_LIMIT=3
# AGENT_STALLED_SLICE_LIMIT=3
# AGENT_CONTEXT_CHARS=120000
# AGENT_GOAL_RETRY_BASE_MS=1000
# AGENT_GOAL_RETRY_MAX_MS=30000
# AGENT_ULTRA_CLOUD_CONCURRENCY=4
# AGENT_ULTRA_MAX_DEPTH=8
# AGENT_ULTRA_MAX_NODES=1000
# AGENT_ULTRA_MODULES_MIN=4
# AGENT_ULTRA_MODULES_MAX=12
# AGENT_ULTRA_FIX_ATTEMPTS=3
# AGENT_PROMPT_TRACE_CHARS=256000
# AGENT_ROLE_MEMORY_TTL_HOURS=168
